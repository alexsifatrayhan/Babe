{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "girlfriendName": { "type": "string" },
        "boyfriendName": { "type": "string" },
        "userGender": { "type": "string", "enum": ["boy", "girl"] },
        "aiGender": { "type": "string", "enum": ["boy", "girl"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A single message in a chat thread",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Chat history for a specific user"
    }
  }
}
