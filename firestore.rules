rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - photoURL: string
    //   - girlfriendName: string
    //   - boyfriendName: string
    //   - createdAt: timestamp
    //
    // Collection: users/{userId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - userId: string (required)
    //   - role: string (required, 'user' or 'assistant')
    //   - content: string (required)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             data.email.size() < 255 &&
             (!('girlfriendName' in data) || (data.girlfriendName is string && data.girlfriendName.size() < 50)) &&
             (!('boyfriendName' in data) || (data.boyfriendName is string && data.boyfriendName.size() < 50));
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['userId', 'role', 'content', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.role in ['user', 'assistant'] &&
             data.content is string &&
             data.content.size() < 5000;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /users/{userId}/messages/{messageId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidMessage(request.resource.data);
      allow delete: if isOwner(userId);
    }
  }
}
